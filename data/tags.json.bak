  "sync": {
    "script": "{sh:load {iv}\n\nffmpeg -i $FILE_1 -an v.mp4\nffmpeg -i $FILE_1 a.wav\n\nvd=$(ffprobe -i v.mp4 -select_streams v:0 -show_entries format=duration -v quiet -of csv=\"p=0\")\nad=$(ffprobe -i a.wav -select_streams a:0 -show_entries format=duration -v quiet -of csv=\"p=0\")\nfr=$(ffprobe -v error -select_streams v:0 -show_entries stream=r_frame_rate -of default=nokey=1:noprint_wrappers=1 $FILE_1)\n\n    ffmpeg -i v.mp4 -stream_loop -1 -i a.wav -af \"atempo=$ad/$vd\" -map 0:v -map 1:a -t $vd ./output/whar.mp4\n\n    rm -f v.mp4 a.wav\n\n    diff=$(echo \"scale=6; $vd-$ad\" | bc)\n    speed=$(echo \"scale=6; $ad/$vd\" | bc)\n\n    echo \"Video: $vd\nAudio: $ad\n\nSpeed Used: $speed\nDiff: $diff\"\nelse \n    ffmpeg -i v.mp4 -stream_loop -1 -i a.wav -vf \"setpts=1/($vd/$ad)*PTS\",fps=$fr -map 0:v -map 1:a -t $vd ./output/whar.mp4\n\n    rm -f v.mp4 a.wav\n\n    diff=$(echo \"scale=6; $vd-$ad\" | bc)\n    speed=$(echo \"scale=6; $vd/$ad\" | bc)\n\n    echo \"Video: $vd\nAudio: $ad\n\nSpeed Used: $speed\nDiff: $diff\"\nfi}",
    "ownerId": "1431176242614501538",
    "ownerUsername": "btve436",
    "createdAt": "2026-06-14T17:08:22.422Z",
    "updatedAt": "2026-06-21T16:04:30.830Z"
  },

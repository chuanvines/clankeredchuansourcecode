  "ihtxfc": {
    "script": "{if:{tag:745467049572082899}|=|true|then:{js:console.error(`You are currently banned from using this tag`)}|else:\n{set:string|{substring:{args}|{indexof:{arg:2}|{args}}}}\n{set:vidlen|{sh:\nload {iv}\nffprobe -i $FILE_1 -show_entries format=duration -v quiet -of csv=\"p=0\"\n}}\n{set:time|{if:{arg:1}|=|vidlen|then:{get:vidlen}|else:{arg:1}}}\n\n{set:code|\nload {iv}\n\n{js:const n = {arg:0};\nconst time = parseFloat(`{get:time}`.trim());\nconst segdur = time / n;\nconst segs = [...Array(n)].map((_, i) => `ffmpeg -i $FILE_1 -ss ${i * segdur} -t ${segdur} {get:string} ${i+1}.ts`);\nconst concat = [...Array(n)].map((_, i) => `${i+1}.ts`).join(\"|\");\nsegs.forEach(s => console.log(s));\nconsole.log(`ffmpeg -i \"concat:${concat}\" ./output/ihtx_custom.mp4`);\n}}\n⚠️ Warning: Make sure you use `.t sync` afterwards to make sure the video is synced to the audio\n{sh:{js:console.log(`{get:code}`)}}\n}",

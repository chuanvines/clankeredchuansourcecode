  "nameless_effect_2.0": {
    "script": "{sh:\nload {iv}\nload https://files.catbox.moe/dg5tyh.mp4\nload https://files.catbox.moe/s16tx2.mp4\nd=$(ffprobe -i $FILE_1 -show_entries format=duration -v quiet -of csv=\"p=0\")\nw=$(ffprobe -v error -select_streams v:0 -show_entries stream=width -of default=nw=1:nk=1 $FILE_1)\nh=$(ffprobe -v error -select_streams v:0 -show_entries stream=height -of default=nw=1:nk=1 $FILE_1)\nffmpeg -i $FILE_1 -i $FILE_2 -i $FILE_3 -filter_complex \"[0]format=gbrp[v1];[1]format=gray,gblur=40,scale=$w:$h,frei0r=contrast0r:\"0.25\"[v2];[2]format=gray,gblur=40,scale=$w:$h,frei0r=contrast0r:\"0.25\"[v3];[v1][v2][v3]displace\" 1.mp4\nffmpeg -i 1.mp4 0.wav\nsox 0.wav 1.wav pitch -2400\nffmpeg -i 1.mp4 -i 1.wav -map 0:v -map 1:a 2.mp4\nffmpeg -i 2.mp4 -af rubberband=pitch='2^(24/12)':formant=712923000 -pix_fmt yuv420p ./output/jshah.mp4}",
    "ownerId": "1431176242614501538",
    "ownerUsername": "btve436",
    "createdAt": "2026-06-30T10:06:06.057Z",
    "updatedAt": "2026-06-30T10:10:16.794Z"
  },

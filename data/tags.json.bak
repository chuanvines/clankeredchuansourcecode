  "gm43": {
    "script": "{sh:\nload {iv}\n\nw=$(ffprobe -v error -select_streams v:0 -show_entries stream=width -of default=nw=1:nk=1 $FILE_1)\nh=$(ffprobe -v error -select_streams v:0 -show_entries stream=height -of default=nw=1:nk=1 $FILE_1)\nfc=$(ffprobe -v error -select_streams v:0 -show_entries stream=nb_frames -of default=nokey=1:noprint_wrappers=1 $FILE_1)\nd=$(ffprobe -i $FILE_1 -show_entries format=duration -v quiet -of csv=\"p=0\")\n\nffmpeg -i $FILE_1 -vf negate,huesaturation=hue=-144:strength=100,format=yuv444p,scale=640:640,\"geq='p(X-((sin((T*5*0+(0*15))+(Y/H)*(PI*0)))*(-15*0)),Y-((sin((T*5*0+(0*15))+(X/W)*(PI*10)))*(-15*1)))'\",scale=$w:$h,setsar=1:1,format=yuv420p,crop=$w/2:$h,scale=$w:$h,setsar=1,format=yuv444p,\"geq='p(W*0.5+(X-W*0.5)*max(1-(1)*gauss(-3.3333*pow(hypot((X-W*0.5)/(W*0.5),(Y-H*0.5)/(H*0.5)),2)),0),H*0.5+(Y-H*0.5)*max(1-(1)*gauss(-3.3333*pow(hypot((X-W*0.5)/(W*0.5),(Y-H*0.5)/(H*0.5)),2)),0))'\",scale=iw:ih,format=yuv420p -filter_complex \"[0:a]rubberband=formant=712923000:pitch=2^(-2/12)[a1];[0:a]rubberband=formant=712923000:pitch=2^(0/12)[a2];[0:a]rubberband=formant=712923000:pitch=2^(10/12)[a3];[a1][a2][a3]amix=3,volume=3,atrim=0.02[outa]\" -map 0:v -map \"[outa]\" ./output/gm43.mp4}",
    "ownerId": "1387479962323255306",
    "ownerUsername": "yasinreturns",
    "createdAt": "2026-06-16T14:08:39.521Z",
    "updatedAt": "2026-06-16T14:12:15.064Z"
  },

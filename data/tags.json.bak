  "center-effects-fixed": {
    "script": "{imagescript:load {iv} 1\nget 1 width w\nget 1 height h\ncopy 1 2\ncopy 1 3\ncopy 1 4\ncopy 1 5\nforeachframe 1 0 1fc \"rotate 1x (180*(idx/1fc)) none true\"\nrotate 1 90\nwave 1 -h/9 w/1.75\nrotate 1 -90\ncover 1 w h\ncopy 1 1$\nconvert 1$ audio/wav\naudiopitch 1$ 2**(-4/12)\nrepeatduration 1$ 1d\naudioputreplace 1 1$\nhueshifthsv 2 65\nexplode 2 1.5\nrotate 2 90\nwave 2 h/8 w/3.6\nrotate 2 -90\ncover 2 w h\nwave 2 -h/12 w/2\ncover 2 w h\ncopy 2 2$\nconvert 2$ audio/wav\naudiopitch 2$ 2**(6/12)\nrepeatduration 2$ 2d\naudioputreplace 2 2$\nhueshifthsv 3 -90\ndetunnel 3\nwiggle 3 right 30 4\ntunnel 3\ncopy 3 3$\nconvert 3$ audio/wav\naudiopitch 3$ 2**(-6/12)\nrepeatduration 3$ 3d\naudioputreplace 3 3$\nhaah 4\nforeachframe 4 0 4fc \"swirl 4x (-90*((idx-4fc)/4fc))\"\naudiopitch 4 2**(-8/12)\nbitrate 4 0 32000\ngrayscale 5\nhuecurvergba 5 red 0 0 0 0\nhuecurvergba 5 green 0.5 0 0 0\nhuecurvergba 5 blue 0.5 0.2 0.7 1\ncopy 5 5$\nconvert 5$ audio/wav\naudiopitch 5$ 2**(-2/12)\nrepeatduration 5$ 5d\naudioputreplace 5 5$\nconcatmultiple 1 2 3 4 5}",
    "ownerId": "1439196394673147905",
    "ownerUsername": "yanis2206",
    "createdAt": "2026-06-11T15:46:56.953Z",
    "updatedAt": "2026-06-11T15:49:11.617Z"

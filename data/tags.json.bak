  "viciousgm": {
    "script": "{sh:\nload {iv}\n\nw=$(ffprobe -v error -select_streams v:0 -show_entries stream=width -of default=nw=1:nk=1 $FILE_1)\nh=$(ffprobe -v error -select_streams v:0 -show_entries stream=height -of default=nw=1:nk=1 $FILE_1)\nfc=$(ffprobe -v error -select_streams v:0 -show_entries stream=nb_frames -of default=nokey=1:noprint_wrappers=1 $FILE_1)\nd=$(ffprobe -i $FILE_1 -show_entries format=duration -v quiet -of csv=\"p=0\")\n\nffmpeg -i $FILE_1 -vf format=yuv444p,negate,huesaturation=hue=180:strength=100,crop=$w:$h/2,scale=$w:$h,setsar=1,format=yuv444p,scale=640:640,\"geq='p(X-((sin((T*5*8+(0*15))+(Y/H)*(PI*10)))*(-15*1)),Y-((sin((T*5*0+(0*15))+(X/W)*(PI*0)))*(-15*0)))'\",scale=$w:$h,setsar=1:1,format=yuv420p -filter_complex \"[0:a]rubberband=formant=712923000:transients=crisp:detector=percussive:smoothing=2.14748e+09/4.9:pitchq=quality:pitch=2^(-8/12)[a1];[0:a]rubberband=formant=712923000:transients=crisp:detector=percussive:smoothing=2.14748e+09/4.9:pitchq=quality:pitch=2^(-4/12)[a2];[a1][a2]amix=2,volume=2,atrim=0.02[outa]\" -map 0:v -map \"[outa]\" ./output/wave.mp4}\n}",
    "ownerId": "1387479962323255306",
    "ownerUsername": "yasinreturns",
    "createdAt": "2026-06-30T17:02:36.663Z",
    "updatedAt": "2026-06-30T17:02:36.663Z"
  },
